# ─── Brand ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME="Liga CUBB"
NEXT_PUBLIC_BRAND_SUBTITLE="Club Universitario de Bahía Blanca"
# Hex color used across NavBar, Footer, Drawer, and the MUI theme
NEXT_PUBLIC_PRIMARY_COLOR="#A60000"
# Path inside /public (e.g. /assets/logo.png) or an absolute HTTPS URL
NEXT_PUBLIC_LOGO_PATH="/assets/logo_2025.png"
NEXT_PUBLIC_LOGO_WIDTH=200
NEXT_PUBLIC_LOGO_HEIGHT=100

# ─── Contact ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_HANDLE="ligacubb"
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/ligacubb"
NEXT_PUBLIC_EMAIL="ligacubb@gmail.com"

# ─── Home page ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_HERO_VIDEO_PATH="/assets/video-home.mp4"
NEXT_PUBLIC_CATEGORY_BANNER_PATH="/assets/category_banner.jpg"
# JSON array of slide objects — omit to use the defaults defined in tenant.ts
# NEXT_PUBLIC_HOME_SLIDES='[{"title":"Cat A","imagePath":"/assets/cat_a_mas.jpg","categoryName":"A","gender":"male"}]'

# ─── SEO / Meta ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_TITLE="Liga CUBB"
NEXT_PUBLIC_COPYRIGHT_YEAR="2025"

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://api.ligacubb.com.ar/"
